<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDisplayName</key>
    <string>DogeSolo</string>

    <key>CFBundleExecutable</key>
    <string>DogeSolo</string>

    <key>CFBundleIdentifier</key>
    <string>org.dogesolo.DogeSolo</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <key>CFBundleName</key>
    <string>DogeSolo</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>CFBundleIconFile</key>
    <string>icon</string>

    <key>LSMinimumSystemVersion</key>
    <string>11.0</string>

    <key>NSHighResolutionCapable</key>
    <true/>

    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2024 DogeSolo Project. MIT License.</string>

    <!-- Permet connexions de xarxa locals (al node Dogecoin) -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>

    <!-- Permisos disc per accedir a ~/.dogecoin i ~/.dogesolo -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <key>LSUIElement</key>
    <false/>

    <key>NSAppleEventsUsageDescription</key>
    <string>DogeSolo necessita accedir al sistema per executar el node Dogecoin.</string>
</dict>
</plist>